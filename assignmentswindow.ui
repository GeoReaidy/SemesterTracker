  <property name="styleSheet">
   <string notr="true">QWidget#AssignmentsWindow {
    background-color: #f5f7fb;
}

QFrame#headerCard,
QFrame#selectionCard,
QFrame#assignmentsCard {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

QLabel#assignmentsTitleLabel {
    color: #111827;
    font-size: 25px;
    font-weight: 700;
}

QLabel#assignmentsSubtitleLabel,
QLabel#selectionHelpLabel {
    color: #64748b;
    font-size: 13px;
}

QLabel#semesterLabel,
QLabel#courseLabel,
QLabel#assignmentsSectionLabel {
    color: #111827;
    font-size: 15px;
    font-weight: 700;
}

QPushButton#addAssignmentButton {
    min-height: 40px;
    padding: 0 18px;
    border: none;
    border-radius: 9px;
    background-color: #2563eb;
    color: #ffffff;
    font-size: 14px;
    font-weight: 600;
}

QPushButton#addAssignmentButton:hover {
    background-color: #1d4ed8;
}

QPushButton#addAssignmentButton:pressed {
    background-color: #1e40af;
}

QPushButton#addAssignmentButton:disabled {
    background-color: #cbd5e1;
    color: #f8fafc;
}

QComboBox#semesterComboBox,
QComboBox#courseComboBox {
    min-height: 38px;
    min-width: 220px;
    padding: 0 12px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background-color: #ffffff;
    color: #334155;
    font-size: 13px;
}

QComboBox#semesterComboBox:hover,
QComboBox#courseComboBox:hover {
    border-color: #93c5fd;
}

QComboBox#semesterComboBox:focus,
QComboBox#courseComboBox:focus {
    border: 1px solid #2563eb;
}

QComboBox#semesterComboBox QAbstractItemView,
QComboBox#courseComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #1f2937;
    border: 1px solid #cbd5e1;
    selection-background-color: #dbeafe;
    selection-color: #1f2937;
}

QListWidget#assignmentsListWidget {
    border: none;
    background-color: transparent;
    outline: none;
    color: #1f2937;
    font-size: 14px;
}

QListWidget#assignmentsListWidget::item {
    margin: 4px 0;
    border: none;
    background-color: transparent;
}

QListWidget#assignmentsListWidget::item:hover {
    background-color: transparent;
}

QListWidget#assignmentsListWidget::item:selected {
    background-color: transparent;
    color: #1f2937;
}

QLabel#emptyStateTitleLabel {
    color: #334155;
    font-size: 16px;
    font-weight: 700;
}

QLabel#emptyStateLabel {
    color: #94a3b8;
    font-size: 14px;
}</string>
