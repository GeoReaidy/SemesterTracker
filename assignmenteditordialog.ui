  <property name="styleSheet">
   <string notr="true">QDialog#AssignmentEditorDialog {
    background-color: #f8fafc;
}
QFrame#contentCard {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
}
QLabel#dialogTitleLabel {
    color: #0f172a;
    font-size: 22px;
    font-weight: 700;
}
QLabel#dialogSubtitleLabel {
    color: #64748b;
    font-size: 13px;
}
QLabel#courseLabel,
QLabel#assignmentNameLabel,
QLabel#weightLabel,
QLabel#gradeLabel,
QLabel#dueDateLabel {
    color: #334155;
    font-size: 13px;
    font-weight: 600;
}
QLabel#courseValueLabel {
    min-height: 38px;
    padding: 0 10px;
    color: #1e3a8a;
    background-color: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 8px;
}
QLineEdit,
QSpinBox,
QDoubleSpinBox,
QDateEdit {
    min-height: 38px;
    padding: 0 10px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background-color: #ffffff;
    color: #1f2937;
}
QLineEdit:focus,
QSpinBox:focus,
QDoubleSpinBox:focus,
QDateEdit:focus {
    border-color: #2563eb;
}
QLineEdit:disabled,
QSpinBox:disabled,
QDoubleSpinBox:disabled,
QDateEdit:disabled {
    background-color: #f1f5f9;
    color: #94a3b8;
}
QCheckBox {
    color: #334155;
    font-size: 13px;
    font-weight: 600;
    spacing: 8px;
}
QFrame#gradeFrame,
QFrame#dueDateFrame {
    background-color: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 9px;
}
QLabel#validationLabel {
    color: #b91c1c;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 7px;
    padding: 8px;
}
QDialogButtonBox QPushButton {
    min-width: 96px;
    min-height: 38px;
    padding: 0 16px;
    border-radius: 8px;
    font-weight: 600;
}
QDialogButtonBox QPushButton[text="Save"] {
    background-color: #2563eb;
    color: #ffffff;
    border: none;
}
QDialogButtonBox QPushButton[text="Save"]:hover {
    background-color: #1d4ed8;
}
QDialogButtonBox QPushButton[text="Cancel"] {
    background-color: #ffffff;
    color: #334155;
    border: 1px solid #cbd5e1;
}</string>
