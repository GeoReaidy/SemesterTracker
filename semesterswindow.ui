    min-height: 40px;
    padding: 0 18px;
    border: none;
    border-radius: 9px;
    background-color: #2563eb;
    color: #ffffff;
    font-size: 14px;
    font-weight: 600;
}
QPushButton#addSemesterButton:hover { background-color: #1d4ed8; }
QPushButton#addSemesterButton:pressed { background-color: #1e40af; }
QComboBox#semesterFilterComboBox {
    min-height: 36px;
    padding: 0 12px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background-color: #ffffff;
    color: #334155;
    font-size: 13px;
}
QListWidget#semestersListWidget {
    border: none;
    background-color: transparent;
    outline: none;
    color: #1f2937;
    font-size: 14px;
}
QListWidget#semestersListWidget::item {
    margin: 4px 0;
    border: none;
    background-color: transparent;
}
QListWidget#semestersListWidget::item:hover {
    background-color: transparent;
}
QListWidget#semestersListWidget::item:selected {
    background-color: transparent;
    color: #1f2937;
}
QLabel#emptyStateLabel {
    color: #94a3b8;
    font-size: 14px;
}</string>
