  <property name="styleSheet">
   <string notr="true">QMainWindow,
QWidget#centralwidget {
    background-color: #f5f7fb;
}

QFrame#accentPanel {
    background-color: #2563eb;
    border-radius: 20px;
}

QLabel#brandTitleLabel {
    color: #ffffff;
    font-size: 31px;
    font-weight: 700;
}

QLabel#brandTextLabel {
    color: #dbeafe;
    font-size: 14px;
}

QLabel#brandFeatureLabel {
    color: #eff6ff;
    font-size: 13px;
}

QFrame#authCard {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
}

QLabel[authTitle="true"] {
    color: #111827;
    font-size: 27px;
    font-weight: 700;
}

QLabel[authSubtitle="true"] {
    color: #64748b;
    font-size: 13px;
}

QLabel[authFieldLabel="true"] {
    color: #334155;
    font-size: 13px;
    font-weight: 600;
}

QLabel#authMessageLabel {
    color: #b91c1c;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    padding: 9px 10px;
}

QLineEdit,
QSpinBox {
    min-height: 42px;
    padding: 0 13px;
    color: #111827;
    background-color: #ffffff;
    border: 1px solid #cbd5e1;
    border-radius: 9px;
    font-size: 14px;
}

QLineEdit:focus,
QSpinBox:focus {
    border: 2px solid #2563eb;
}

QPushButton[authPrimary="true"] {
    min-height: 42px;
    color: #ffffff;
    background-color: #2563eb;
    border: 1px solid #2563eb;
    border-radius: 9px;
    padding: 0 18px;
    font-size: 14px;
    font-weight: 600;
}

QPushButton[authPrimary="true"]:hover {
    background-color: #1d4ed8;
    border-color: #1d4ed8;
}

QPushButton[authPrimary="true"]:pressed {
    background-color: #1e40af;
    border-color: #1e40af;
}

QPushButton[authSecondary="true"] {
    min-height: 42px;
    color: #2563eb;
    background-color: #ffffff;
    border: 1px solid #bfdbfe;
    border-radius: 9px;
    padding: 0 18px;
    font-size: 14px;
    font-weight: 600;
}

QPushButton[authSecondary="true"]:hover {
    background-color: #eff6ff;
}

QPushButton[authLink="true"] {
    min-height: 30px;
    color: #2563eb;
    background-color: transparent;
    border: none;
    padding: 0 4px;
    font-size: 13px;
    font-weight: 600;
}

QPushButton[authLink="true"]:hover {
    color: #1d4ed8;
    text-decoration: underline;
}

QPushButton:disabled {
    color: #94a3b8;
    background-color: #e2e8f0;
    border-color: #e2e8f0;
}</string>
