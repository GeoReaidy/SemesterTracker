    min-height: 38px;
    padding: 0 10px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background-color: #ffffff;
    color: #1f2937;
}
QLineEdit:focus,
QComboBox:focus,
QSpinBox:focus {
    border-color: #2563eb;
}
QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #1f2937;
    selection-background-color: #dbeafe;
    selection-color: #1f2937;
    border: 1px solid #cbd5e1;
    outline: none;
}
QFrame#retakeFrame {
    background-color: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 9px;
}
QCheckBox#retakeCheckBox {
    color: #1e3a8a;
    font-weight: 600;
    spacing: 8px;
}
QLabel#retakeHelpLabel {
    color: #475569;
    font-size: 12px;
}
QLabel#editNoticeLabel {
    color: #475569;
    background-color: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 7px;
    padding: 8px;
}
QLabel#validationLabel {
    color: #b91c1c;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 7px;
    padding: 8px;
}
QDialogButtonBox QPushButton {
    min-width: 96px;
    min-height: 38px;
    padding: 0 16px;
    border-radius: 8px;
    font-weight: 600;
}
QDialogButtonBox QPushButton[text="Save"] {
    background-color: #2563eb;
    color: #ffffff;
    border: none;
}
QDialogButtonBox QPushButton[text="Save"]:hover {
    background-color: #1d4ed8;
}
QDialogButtonBox QPushButton[text="Cancel"] {
    background-color: #ffffff;
    color: #334155;
    border: 1px solid #cbd5e1;
}</string>
