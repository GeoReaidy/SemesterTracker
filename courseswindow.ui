  <property name="styleSheet">
   <string notr="true">QWidget#CoursesWindow {
    background-color: #f5f7fb;
}
QFrame#headerCard,
QFrame#semesterSelectorCard,
QFrame#coursesCard {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}
QLabel#coursesTitleLabel {
    color: #111827;
    font-size: 25px;
    font-weight: 700;
}
QLabel#coursesSubtitleLabel,
QLabel#semesterHelpLabel {
    color: #64748b;
    font-size: 13px;
}
QLabel#semesterSelectorLabel,
QLabel#coursesSectionLabel {
    color: #111827;
    font-size: 16px;
    font-weight: 700;
}
QPushButton#addCourseButton {
    min-height: 40px;
    padding: 0 18px;
    border: none;
    border-radius: 9px;
    background-color: #2563eb;
    color: #ffffff;
    font-size: 14px;
    font-weight: 600;
}
QPushButton#addCourseButton:hover {
    background-color: #1d4ed8;
}
QPushButton#addCourseButton:pressed {
    background-color: #1e40af;
}
QPushButton#addCourseButton:disabled {
    background-color: #cbd5e1;
    color: #f8fafc;
}
QComboBox#semesterComboBox {
    min-height: 38px;
    min-width: 230px;
    padding: 0 12px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background-color: #ffffff;
    color: #334155;
    font-size: 13px;
}
QComboBox#semesterComboBox:hover {
    border-color: #93c5fd;
}
QComboBox#semesterComboBox:focus {
    border: 1px solid #2563eb;
}
QComboBox#semesterComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #1f2937;
    border: 1px solid #cbd5e1;
    selection-background-color: #dbeafe;
    selection-color: #1f2937;
}
QListWidget#coursesListWidget {
    border: none;
    background-color: transparent;
    outline: none;
    color: #1f2937;
    font-size: 14px;
}
QListWidget#coursesListWidget::item {
    padding: 0;
    margin: 4px 0;
    border: none;
    background-color: transparent;
}
QListWidget#coursesListWidget::item:hover {
    background-color: transparent;
    border: none;
}
QListWidget#coursesListWidget::item:selected {
    background-color: transparent;
    color: #1f2937;
    border: none;
}
QLabel#emptyStateTitleLabel {
    color: #334155;
    font-size: 16px;
    font-weight: 700;
}
QLabel#emptyStateLabel {
    color: #94a3b8;
    font-size: 14px;
}</string>
