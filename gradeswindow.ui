  <property name="styleSheet">
   <string notr="true">QWidget#GradesWindow {
    background-color: #f5f7fb;
}

QFrame#headerCard,
QFrame#semesterCard,
QFrame#summaryCard,
QFrame#coursesCard {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

QLabel#gradesTitleLabel {
    color: #111827;
    font-size: 25px;
    font-weight: 700;
}

QLabel#gradesSubtitleLabel,
QLabel#semesterHelpLabel,
QLabel#summaryCaptionLabel,
QLabel#emptyStateLabel {
    color: #64748b;
    font-size: 13px;
}

QLabel#semesterSectionLabel,
QLabel#courseGradesLabel {
    color: #111827;
    font-size: 15px;
    font-weight: 700;
}

QLabel#semesterGpaTitleLabel,
QLabel#averageGradeTitleLabel,
QLabel#completedCoursesTitleLabel {
    color: #64748b;
    font-size: 13px;
    font-weight: 600;
}

QLabel#semesterGpaValueLabel,
QLabel#averageGradeValueLabel,
QLabel#completedCoursesValueLabel {
    color: #111827;
    font-size: 26px;
    font-weight: 700;
}

QComboBox#semesterComboBox {
    min-height: 38px;
    min-width: 240px;
    padding: 0 12px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background-color: #ffffff;
    color: #334155;
    font-size: 13px;
}

QComboBox#semesterComboBox:hover {
    border-color: #93c5fd;
}

QComboBox#semesterComboBox:focus {
    border: 1px solid #2563eb;
}

QComboBox#semesterComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #1f2937;
    border: 1px solid #cbd5e1;
    selection-background-color: #dbeafe;
    selection-color: #1f2937;
}

QListWidget#courseGradesListWidget {
    border: none;
    background-color: transparent;
    outline: none;
    color: #1f2937;
    font-size: 14px;
}

QListWidget#courseGradesListWidget::item {
    margin: 4px 0;
    border: none;
    background-color: transparent;
}

QListWidget#courseGradesListWidget::item:hover,
QListWidget#courseGradesListWidget::item:selected {
    background-color: transparent;
    color: #1f2937;
}

QLabel#emptyStateTitleLabel {
    color: #334155;
    font-size: 16px;
    font-weight: 700;
}</string>
