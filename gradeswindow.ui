  <property name="styleSheet">
   <string notr="true">QWidget#GradesWindow {
    background-color: #f5f7fb;
}

QFrame#headerCard,
QFrame#summaryCard,
QFrame#trendCard,
QFrame#coursesCard {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}

QLabel#gradesTitleLabel {
    color: #111827;
    font-size: 24px;
    font-weight: 700;
}

QLabel#gradesSubtitleLabel,
QLabel#semesterHelpLabel,
QLabel#summaryCaptionLabel,
QLabel#trendHelpLabel,
QLabel#emptyStateLabel {
    color: #64748b;
    font-size: 12px;
}

QLabel#semesterSectionLabel,
QLabel#trendTitleLabel,
QLabel#courseGradesLabel {
    color: #111827;
    font-size: 14px;
    font-weight: 700;
}

QLabel#semesterGpaTitleLabel,
QLabel#averageGradeTitleLabel,
QLabel#completedCoursesTitleLabel,
QLabel#projectedCgpaTitleLabel {
    color: #64748b;
    font-size: 12px;
    font-weight: 600;
}

QLabel#semesterGpaValueLabel,
QLabel#averageGradeValueLabel,
QLabel#completedCoursesValueLabel,
QLabel#projectedCgpaValueLabel {
    color: #111827;
    font-size: 22px;
    font-weight: 700;
}

QComboBox#semesterComboBox {
    min-height: 34px;
    min-width: 230px;
    padding: 0 11px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background-color: #ffffff;
    color: #334155;
    font-size: 12px;
}

QComboBox#semesterComboBox:hover { border-color: #93c5fd; }
QComboBox#semesterComboBox:focus { border: 1px solid #2563eb; }
QComboBox#semesterComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #1f2937;
    border: 1px solid #cbd5e1;
    selection-background-color: #dbeafe;
    selection-color: #1f2937;
}

QListWidget#courseGradesListWidget {
    border: none;
    background-color: transparent;
    outline: none;
    color: #1f2937;
    font-size: 13px;
}

QListWidget#courseGradesListWidget::item {
    margin: 3px 0;
    border: none;
    background-color: transparent;
}

QListWidget#courseGradesListWidget::item:hover,
QListWidget#courseGradesListWidget::item:selected {
    background-color: transparent;
    color: #1f2937;
}

QLabel#emptyStateTitleLabel {
    color: #334155;
    font-size: 15px;
    font-weight: 700;
}</string>
