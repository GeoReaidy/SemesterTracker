  <property name="styleSheet">
   <string notr="true">QDialog#SemesterEditorDialog {
    background-color: #f8fafc;
}
QFrame#contentCard {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
}
QLabel#dialogTitleLabel {
    color: #0f172a;
    font-size: 22px;
    font-weight: 700;
}
QLabel#dialogSubtitleLabel {
    color: #64748b;
    font-size: 13px;
}
QLabel#termLabel,
QLabel#yearLabel,
QLabel#completedCreditsLabel,
QLabel#semesterGpaLabel {
    color: #334155;
    font-size: 13px;
    font-weight: 600;
}
QComboBox,
QSpinBox,
QDoubleSpinBox {
    min-height: 38px;
    padding: 0 10px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background-color: #ffffff;
    color: #1f2937;
}
QComboBox:focus,
QSpinBox:focus,
QDoubleSpinBox:focus {
    border-color: #2563eb;
}
QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #1f2937;
    selection-background-color: #dbeafe;
    selection-color: #1f2937;
    border: 1px solid #cbd5e1;
    outline: none;
}
QCheckBox {
    color: #334155;
    spacing: 8px;
}
QCheckBox:disabled {
    color: #94a3b8;
}
QFrame#completedFieldsFrame {
    background-color: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 9px;
}
QLabel#conversionNoticeLabel {
    color: #92400e;
    background-color: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 7px;
    padding: 8px;
}
QLabel#validationLabel {
    color: #b91c1c;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 7px;
    padding: 8px;
}
QDialogButtonBox QPushButton {
    min-width: 96px;
    min-height: 38px;
    padding: 0 16px;
    border-radius: 8px;
    font-weight: 600;
}
QDialogButtonBox QPushButton[text="Save"] {
    background-color: #2563eb;
    color: #ffffff;
    border: none;
}
QDialogButtonBox QPushButton[text="Save"]:hover {
    background-color: #1d4ed8;
}
QDialogButtonBox QPushButton[text="Cancel"] {
    background-color: #ffffff;
    color: #334155;
    border: 1px solid #cbd5e1;
}</string>
