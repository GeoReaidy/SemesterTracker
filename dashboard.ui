  <property name="styleSheet">
   <string notr="true">QWidget#Dashboard {
    background-color: #f5f7fb;
}
QFrame#sidebarFrame {
    background-color: #ffffff;
    border-right: 1px solid #e2e8f0;
}
QLabel#appTitleLabel {
    color: #111827;
    font-size: 22px;
    font-weight: 700;
}
QPushButton[class="navButton"] {
    min-height: 42px;
    padding: 0 14px;
    text-align: left;
    border: none;
    border-radius: 9px;
    background-color: transparent;
    color: #334155;
    font-size: 14px;
}
QPushButton[class="navButton"]:hover {
    background-color: #eff6ff;
    color: #2563eb;
}
QPushButton[class="navButton"]:checked {
    background-color: #dbeafe;
    color: #2563eb;
    font-weight: 600;
}
QPushButton#logoutButton {
    min-height: 42px;
    padding: 0 14px;
    text-align: left;
    border: none;
    border-radius: 9px;
    background-color: transparent;
    color: #dc2626;
    font-size: 14px;
}
QPushButton#logoutButton:hover {
    background-color: #fee2e2;
}
QFrame[class="card"] {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
}
QLabel[class="sectionTitle"] {
    color: #111827;
    font-size: 16px;
    font-weight: 700;
}
QPushButton[class="linkButton"] {
    border: none;
    background: transparent;
    color: #2563eb;
    font-size: 13px;
}
QPushButton[class="linkButton"]:hover {
    text-decoration: underline;
}
QListWidget {
    border: none;
    background: transparent;
    outline: none;
    color: #1f2937;
    font-size: 13px;
}
QListWidget::item {
    min-height: 42px;
    padding: 5px 8px;
    border-bottom: 1px solid #eef2f7;
}
QListWidget::item:selected {
    background-color: #eff6ff;
    color: #1f2937;
}
QTableWidget {
    border: none;
    background: transparent;
    gridline-color: #e5e7eb;
    color: #334155;
    font-size: 12px;
}
QHeaderView::section {
    background-color: #f8fafc;
    color: #475569;
    border: none;
    border-bottom: 1px solid #e5e7eb;
    padding: 7px;
    font-weight: 600;
}
QProgressBar {
    min-height: 18px;
    max-height: 18px;
    border: none;
    border-radius: 9px;
    background-color: #e5e7eb;
    text-align: center;
    color: #ffffff;
    font-size: 11px;
    font-weight: 600;
}
QProgressBar::chunk {
    background-color: #2563eb;
    border-radius: 9px;
}</string>
